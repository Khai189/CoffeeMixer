# Database URLs
# For Railway: These will be automatically provided by Railway when you add a PostgreSQL database
# For local development: Use your local PostgreSQL connection string
DATABASE_URL="postgresql://username:password@hostname:5432/database"
DIRECT_DATABASE_URL="postgresql://username:password@hostname:5432/database"

# Session Secret
# For Railway: Generate a random string using: openssl rand -base64 32
# IMPORTANT: This should be different in production!
SESSION_SECRET="your-secret-key-here-make-it-random-and-long"

# Node Environment (automatically set by Railway)
NODE_ENV="production"
